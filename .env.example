# =============================================================================
# Pasteur AI — copy thành file `.env` và điền giá trị thật.
# Không commit file `.env`. Chỉ commit `.env.example` (không có secret).
# =============================================================================

# --- Database (chọn một trong hai cách) ---------------------------------------

# Cách 1 — SQLite (dev nhanh, mặc định nếu không cấu hình Postgres)
# DATABASE_URL=sqlite:///./pasteur.db

# Cách 2 — Supabase Postgres (mật khẩu ghi trực tiếp, không cần URL-encode)
# Direct: host db.<project-ref>.supabase.co, port 5432
# Pooler: host aws-0-<region>.pooler.supabase.com, port 6543, user postgres.<project-ref>
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# --- Google Gemini (LLM + STT) -------------------------------------------------
# Lấy key: https://aistudio.google.com/apikey
# Đặt một trong hai tên (SDK Google cũng nhận GOOGLE_API_KEY):
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Model mặc định trong code: gemini-2.5-flash (đổi nếu cần)
GEMINI_MODEL=gemini-2.5-flash

# --- TTS (edge-tts — không cần API key) ---------------------------------------
# TTS_VOICE=vi-VN-HoaiMyNeural
# TTS_MAX_CHARS=5000

# --- Vector RAG (tùy chọn, mặc định bật) --------------------------------------
# RAG_ENABLED=true
# RAG_EMBEDDING_DIMS=128
# RAG_TOP_K=4
# RAG_INDEX_INTERVAL_SECONDS=300
# RAG_MAX_RECORDS_PER_PATIENT=40
