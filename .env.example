# =============================================================================
# Pasteur AI — copy thành file `.env` và điền giá trị thật.
# Không commit file `.env`. Chỉ commit `.env.example` (không có secret).
# =============================================================================

# --- Database (chọn một trong hai cách) ---------------------------------------

# Cách 1 — SQLite (dev nhanh, mặc định nếu không cấu hình Postgres)
# DATABASE_URL=sqlite:///./pasteur.db

# Cách 2 — Supabase Postgres (mật khẩu ghi trực tiếp, không cần URL-encode)
# Direct: host db.<project-ref>.supabase.co, port 5432
# Pooler: host aws-0-<region>.pooler.supabase.com, port 6543, user postgres.<project-ref>
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# --- Groq (chat LLM + Whisper STT — mặc định; ổn trên Render / nhiều khu vực) ----------
# Bắt buộc điền key: https://console.groq.com/
GROQ_API_KEY=
CHAT_LLM_PROVIDER=groq
STT_PROVIDER=groq
# Model chat (xem danh sách model trên Groq Console)
GROQ_MODEL=llama-3.3-70b-versatile
# Whisper STT
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TIMEOUT_SECONDS=60

# --- Google Gemini (tùy chọn — khi CHAT_LLM_PROVIDER=gemini hoặc STT_PROVIDER=gemini)
# Lấy key: https://aistudio.google.com/apikey
# Đặt một trong hai tên (SDK Google cũng nhận GOOGLE_API_KEY):
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Chat model: có thể đặt full slug hoặc alias ngắn: flash | flash_lite
GEMINI_MODEL=gemini-2.5-flash
# Bật để luân phiên chat model flash <-> flash-lite theo từng request
CHAT_MODEL_ROUND_ROBIN=false
# STT model: full slug hoặc alias flash | flash_lite
STT_MODEL=gemini-2.5-flash
# Tự fallback STT sang model còn lại khi quota/rate-limit/not-supported
STT_MODEL_FALLBACK_ENABLED=true
STT_TIMEOUT_SECONDS=20
STT_RETRY_ATTEMPTS=2
VOICE_MAX_AUDIO_BYTES=5242880

# --- LLM Router (offline extension) -------------------------------------------
# Mặc định: api_only (dùng Groq/Gemini theo CHAT_LLM_PROVIDER)
# Tuỳ chọn:
# - local_only: chỉ dùng local model
# - hybrid: ưu tiên local, lỗi thì fallback API
LLM_ROUTER_MODE=api_only
LOCAL_LLM_ENABLED=false
# Ví dụ endpoint local OpenAI-compatible:
# LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
LOCAL_LLM_ENDPOINT=
# Qwen2.5-3B (tuỳ runtime local đặt tên model)
LOCAL_LLM_MODEL=qwen2.5:3b-instruct
LOCAL_LLM_TIMEOUT_SECONDS=20

# --- TTS (edge-tts — không cần API key) ---------------------------------------
# TTS_VOICE=vi-VN-HoaiMyNeural
# TTS_MAX_CHARS=5000
# TTS_TIMEOUT_SECONDS=20

# --- Vector RAG (tùy chọn, mặc định bật) --------------------------------------
# RAG_ENABLED=true
# RAG_EMBEDDING_DIMS=128
# RAG_TOP_K=4
# RAG_INDEX_INTERVAL_SECONDS=300
# RAG_MAX_RECORDS_PER_PATIENT=40
